# Configuration du serveur de signalement GhostHandDesk

# Adresse et port d'écoute
SERVER_HOST=:8443

# Certificats TLS (génération avec openssl)
CERT_FILE=certs/server.crt
KEY_FILE=certs/server.key

# Niveau de logging (debug, info, warn, error)
LOG_LEVEL=info

# Nombre maximum de clients simultanés
MAX_CLIENTS=1000

# Timeout de connexion en secondes
CONNECTION_TIMEOUT=60

# Token d'authentification pour l'endpoint /stats (admin uniquement)
# OBLIGATOIRE EN PRODUCTION — si vide, /stats est accessible sans auth
# Générer avec: openssl rand -hex 32
# ATTENTION: Ne jamais commiter le vrai token ici
STATS_TOKEN=

# Origines WebSocket autorisées (séparées par des virgules)
# OBLIGATOIRE EN PRODUCTION — si vide, les origines par défaut sont utilisées
# Exemple: ALLOWED_ORIGINS=https://app.example.com,tauri://localhost
ALLOWED_ORIGINS=

# Désactiver la vérification d'origine (DÉVELOPPEMENT UNIQUEMENT — JAMAIS EN PRODUCTION)
DISABLE_ORIGIN_CHECK=false
